            "Moisture_Level_Medium": [1 if moisture_level == "Medium" else 0],
            "Moisture_Level_High": [1 if moisture_level == "High" else 0]
        }

        input_df = pd.DataFrame(input_dict)

        # ---------------------------
        # Scale and Predict
