@st.cache_resource
def load_soil_crop_model():
    """
    Loads the Soil-to-Crop model, scaler, and label encoder.
    """
    model = tf.keras.models.load_model("smart_soil_crop_model.h5")  # trained model
    scaler = joblib.load("soil_scaler.pkl")                          # trained scaler
    encoder = joblib.load("crop_label_encoder.pkl")                  # label encoder
    return model, scaler, encoder

    # ---------------------------
    # Input Soil/Environment Parameters
    # ---------------------------
    col1, col2 = st.columns(2)
    with col1:
        temperature = st.number_input("Temperature (°C)", 0, 50, 25)
        humidity = st.number_input("Humidity (%)", 0, 100, 50)
        moisture = st.number_input("Moisture (%)", 0, 100, 40)
        nitrogen = st.number_input("Nitrogen (ppm)", 0, 100, 10)
        phosphorous = st.number_input("Phosphorous (ppm)", 0, 100, 10)
    with col2:
        potassium = st.number_input("Potassium (ppm)", 0, 100, 10)
        soil_type = st.selectbox("Soil Type", ["Sandy", "Loamy", "Clayey", "Red", "Black"])
        ph = st.number_input("pH", 0.0, 14.0, 7.0)

    if st.button("🌾 Recommend Crop"):

        # ---------------------------
        # Feature Engineering
        # ---------------------------
        # Moisture Level
        if moisture < 35:
            moisture_level = "Low"
        elif 35 <= moisture <= 60:
            moisture_level = "Medium"
        else:
            moisture_level = "High"

        # pH Category
        if ph < 6.5:
            ph_category = "Acidic"
        elif 6.5 <= ph <= 7.5:
            ph_category = "Neutral"
        else:
            ph_category = "Alkaline"

        # Soil Suitability Score
        soil_score = 0
        soil_score += 40 if ph_category == "Neutral" else 20
        soil_score += 30 if moisture_level == "Medium" else 10
        nutrient_score = min((nitrogen + phosphorous + potassium) / 3, 30)
        soil_score += nutrient_score

        # ---------------------------
        # Build Input DataFrame
        # ---------------------------
        input_dict = {
            "Temparature": [temperature],
            "Humidity": [humidity],
            "Moisture": [moisture],
            "Nitrogen": [nitrogen],
            "Phosphorous": [phosphorous],
            "Potassium": [potassium],
            "Soil_Suitability_Score": [soil_score],
            # One-hot Soil Type
            "Soil Type_Sandy": [1 if soil_type == "Sandy" else 0],
            "Soil Type_Loamy": [1 if soil_type == "Loamy" else 0],
            "Soil Type_Clayey": [1 if soil_type == "Clayey" else 0],
            "Soil Type_Red": [1 if soil_type == "Red" else 0],
            "Soil Type_Black": [1 if soil_type == "Black" else 0],
            # One-hot pH Category
            "pH_Category_Acidic": [1 if ph_category == "Acidic" else 0],
