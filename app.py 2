elif option == "Soil-to-Crop Recommendation":

    st.header("🌱 Soil-to-Crop Recommendation")
    soil_model, scaler, encoder = load_soil_crop_model()

    col1, col2 = st.columns(2)
    with col1:
        temperature = st.number_input("Temperature (°C)", 0, 50, 25)
        humidity = st.number_input("Humidity (%)", 0, 100, 50)
        moisture = st.number_input("Moisture (%)", 0, 100, 40)
        nitrogen = st.number_input("Nitrogen (ppm)", 0, 100, 10)
        phosphorous = st.number_input("Phosphorous (ppm)", 0, 100, 10)
    with col2:
        potassium = st.number_input("Potassium (ppm)", 0, 100, 10)
        soil_type = st.selectbox("Soil Type", ["Sandy","Loamy","Clayey","Red","Black"])
        ph = st.number_input("pH", 0.0, 14.0, 7.0)

    if st.button("🌾 Recommend Crop"):
        # Moisture Level
        if moisture < 35: moisture_level = "Low"
        elif 35 <= moisture <= 60: moisture_level = "Medium"
        else: moisture_level = "High"
        # pH Category
        if ph < 6.5: ph_category = "Acidic"
        elif 6.5 <= ph <= 7.5: ph_category = "Neutral"
        else: ph_category = "Alkaline"
        # Soil Score
        soil_score = 0
        soil_score += 40 if ph_category=="Neutral" else 20
        soil_score += 30 if moisture_level=="Medium" else 10
        nutrient_score = min((nitrogen+phosphorous+potassium)/3,30)
        soil_score += nutrient_score
        # Input DataFrame
        input_dict = {
            "Temparature":[temperature],
            "Humidity":[humidity],
            "Moisture":[moisture],
            "Nitrogen":[nitrogen],
            "Phosphorous":[phosphorous],
            "Potassium":[potassium],
            "Soil_Suitability_Score":[soil_score],
            # Soil Type
            "Soil Type_Sandy":[1 if soil_type=="Sandy" else 0],
            "Soil Type_Loamy":[1 if soil_type=="Loamy" else 0],
            "Soil Type_Clayey":[1 if soil_type=="Clayey" else 0],
            "Soil Type_Red":[1 if soil_type=="Red" else 0],
            "Soil Type_Black":[1 if soil_type=="Black" else 0],
            # pH Category
            "pH_Category_Acidic":[1 if ph_category=="Acidic" else 0],
            "pH_Category_Neutral":[1 if ph_category=="Neutral" else 0],
            "pH_Category_Alkaline":[1 if ph_category=="Alkaline" else 0],
            # Moisture Level
            "Moisture_Level_Low":[1 if moisture_level=="Low" else 0],
            "Moisture_Level_Medium":[1 if moisture_level=="Medium" else 0],
            "Moisture_Level_High":[1 if moisture_level=="High" else 0]
        }
        input_df = pd.DataFrame(input_dict)
        input_scaled = scaler.transform(input_df)
        pred = soil_model.predict(input_scaled)
        recommended_crop = encoder.inverse_transform([np.argmax(pred)])
        st.success(f"🌾 Recommended Crop: {recommended_crop[0]}")

