if option == "Climate Modelling":
    st.header("🌍 Climate Modelling & Future Prediction")
    st.subheader("Enter Current Climate Conditions")

    temperature = st.number_input("Temperature (°C):", 0.0, 50.0, 25.0, step=0.01, format="%.2f")
    st.caption("Optimal: 20°C – 35°C")

