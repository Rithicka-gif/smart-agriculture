# 3. SOIL-TO-CROP RECOMMENDATION SECTION
# ============================================================
elif option == "Soil-to-Crop Recommendation":
    st.header("🌱 Soil-to-Crop AI Recommendation")
    
    # Load assets
    try:
        soil_model, scaler, encoder = load_soil_crop_model()
    except Exception as e:
        st.error(f"Error loading model files: {e}")
        st.stop()

    col1, col2 = st.columns(2)
    with col1:
        temperature = st.number_input("Temperature (°C)", 0, 50, 25)
        humidity = st.number_input("Humidity (%)", 0, 100, 50)
        moisture = st.number_input("Moisture (%)", 0, 100, 40)
        nitrogen = st.number_input("Nitrogen (ppm)", 0, 150, 50)
    with col2:
        phosphorous = st.number_input("Phosphorous (ppm)", 0, 150, 50)
        potassium = st.number_input("Potassium (ppm)", 0, 250, 50)
        soil_type_input = st.selectbox("Soil Type", ["Sandy", "Loamy", "Clayey", "Red", "Black"])
        ph_input = st.number_input("pH Level", 0.0, 14.0, 7.0)

    if st.button("🌾 Recommend Crop"):
        # 1. Feature Engineering (Generate raw categories)
        m_lvl = "Low" if moisture < 35 else ("Medium" if moisture <= 60 else "High")
        p_cat = "Acidic" if ph_input < 6.5 else ("Neutral" if ph_input <= 7.5 else "Alkaline")
        
        # Soil Score Calculation
        s_score = (40 if p_cat == "Neutral" else 20) + (30 if m_lvl == "Medium" else 10)
        s_score += min((nitrogen + phosphorous + potassium) / 3, 30)

        # 2. Build Raw Input DataFrame
        # IMPORTANT: Use the exact names your Preprocessor saw during training.
        # Do NOT manually create 'Soil Type_Sandy', etc.
        input_dict = {
            "Temparature": [temperature], 
            "Humidity": [humidity], 
            "Moisture": [moisture],
            "Nitrogen": [nitrogen], 
            "Phosphorous": [phosphorous], 
            "Potassium": [potassium],
            "Soil_Suitability_Score": [s_score],
            "Soil Type": [soil_type_input],      # The preprocessor will encode this
            "pH_Category": [p_cat],             # The preprocessor will encode this
            "Moisture_Level": [m_lvl]            # The preprocessor will encode this
        }
        
        input_df = pd.DataFrame(input_dict)
        
        try:
            # 3. Transform and Predict
            # The 'scaler' (ColumnTransformer) handles the One-Hot encoding automatically
            input_scaled = scaler.transform(input_df)
            
            prediction = soil_model.predict(input_scaled)
            result_idx = np.argmax(prediction)
            crop_name = encoder.inverse_transform([result_idx])[0]
            
            st.success(f"### 🌾 Recommended Crop: **{crop_name}**")
            st.balloons()
        except Exception as e:
            st.error(f"Prediction Error: {e}")
            st.info("Ensure the column names in input_dict match your CSV headers exactly.")
