    if st.button("Analyze Climate"):
        # Logic
        suitability = "High 🌱" if (20 <= temperature <= 35 and 50 <= humidity <= 80) else ("Low ⚠" if (temperature < 15 or rainfall < 30) else "Moderate 🌿")
        drought_risk = "High 🔥" if rainfall < 50 else "Low"
        flood_risk = "High 🌊" if rainfall > 200 else "Low"

        # Projection
        future_temp = temperature + 1.5
        future_rain = rainfall * 0.9

        st.subheader("📊 Results")
        col1, col2, col3 = st.columns(3)
        col1.write(f"**Suitability:** {suitability}")
        col2.write(f"**Drought:** {drought_risk}")
        col3.write(f"**Flood:** {flood_risk}")

        st.subheader("🔮 2050 Projection")
        st.write(f"🌡 Temp: {round(future_temp, 2)}°C | 🌧 Rain: {round(future_rain, 2)}mm")

