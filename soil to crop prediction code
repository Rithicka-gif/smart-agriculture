# File: soil_to_crop.py
# Project: Smart Soil-to-Crop Advisor
# Description: Predicts the best crop based on soil and environmental parameters

import pandas as pd
import numpy as np
from sklearn.model_selection import train_test_split
from sklearn.preprocessing import LabelEncoder, StandardScaler
from tensorflow.keras.models import Sequential
from tensorflow.keras.layers import Dense
import joblib

# 1. Load the dataset
data = pd.read_csv('data_core.csv')

# 2. Feature Engineering (if not already done in CSV)
# pH Category
def ph_category(ph):
    if ph < 6.5:
        return 'Acidic'
    elif 6.5 <= ph <= 7.5:
        return 'Neutral'
    else:
        return 'Alkaline'

# Replace 'Phosphorous' with actual 'Ph' column if exists
data['pH_Category'] = data['Phosphorous'].apply(ph_category)

# Moisture Level
def moisture_level(moisture):
    if moisture < 35:
        return 'Low'
    elif 35 <= moisture <= 60:
        return 'Medium'
    else:
        return 'High'

data['Moisture_Level'] = data['Moisture'].apply(moisture_level)

# Soil Suitability Score
def soil_score(row):
    score = 0
    # pH contribution
    if row['pH_Category'] == 'Neutral':
        score += 40
    elif row['pH_Category'] == 'Acidic' or row['pH_Category'] == 'Alkaline':
        score += 20
    # Moisture contribution
    if row['Moisture_Level'] == 'Medium':
        score += 30
    elif row['Moisture_Level'] == 'Low' or row['Moisture_Level'] == 'High':
        score += 10
    # Nutrients contribution
    nutrient_score = min((row['Nitrogen'] + row['Phosphorous'] + row['Potassium']) / 3, 30)
    score += nutrient_score
    return score

data['Soil_Suitability_Score'] = data.apply(soil_score, axis=1)

# 3. Select Features and Target
numeric_features = ['Temparature', 'Humidity', 'Moisture', 'Nitrogen', 'Phosphorous', 'Potassium', 'Soil_Suitability_Score']
categorical_features = ['Soil Type', 'pH_Category', 'Moisture_Level']

# One-hot encode categorical features
data = pd.get_dummies(data, columns=categorical_features)

X = data[numeric_features + [col for col in data.columns if col.startswith('Soil Type_') 
                             or col.startswith('pH_Category_') 
                             or col.startswith('Moisture_Level_')]]
y = data['Crop Type']  # or 'Crop_Type' depending on your CSV

# Encode target labels
le = LabelEncoder()
y_encoded = le.fit_transform(y)

# 4. Split Dataset
X_train, X_test, y_train, y_test = train_test_split(X, y_encoded, test_size=0.2, random_state=42)

# 5. Scale numeric features
scaler = StandardScaler()
X_train = scaler.fit_transform(X_train)
X_test = scaler.transform(X_test)

# 6. Build Neural Network Model
num_classes = len(le.classes_)
model = Sequential([
    Dense(64, activation='relu', input_shape=(X_train.shape[1],)),
    Dense(32, activation='relu'),
    Dense(num_classes, activation='softmax')
])

model.compile(optimizer='adam', loss='sparse_categorical_crossentropy', metrics=['accuracy'])

# 7. Train Model
model.fit(X_train, y_train, epochs=10, batch_size=8, validation_data=(X_test, y_test))

# 8. Predict Example
sample = X_test[0].reshape(1, -1)
pred_class = model.predict(sample)
predicted_crop = le.inverse_transform([np.argmax(pred_class)])
print("Recommended Crop:", predicted_crop[0])

# 9. Save model, scaler, and encoder for future use
model.save('smart_soil_crop_model.h5')
joblib.dump(scaler, 'soil_scaler.pkl')
joblib.dump(le, 'crop_label_encoder.pkl')
